-- Create indexes
CREATE INDEX idx_users_email ON users(email);
CREATE INDEX idx_ads_category ON ads(category);
CREATE INDEX idx_ads_city ON ads(city);
CREATE INDEX idx_ads_user_id ON ads(user_id);
CREATE INDEX idx_ads_status ON ads(status);
CREATE INDEX idx_ads_premium ON ads(is_premium);
CREATE INDEX idx_ads_created ON ads(created_at DESC);
CREATE INDEX idx_chats_ad_id ON chats(ad_id);
CREATE INDEX idx_chats_buyer_seller ON chats(buyer_id, seller_id);
CREATE INDEX idx_messages_chat_id ON messages(chat_id);
CREATE INDEX idx_messages_created ON messages(created_at);

